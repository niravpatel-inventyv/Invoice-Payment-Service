# Local development environment for docker compose
POSTGRES_DB=invoice_db
POSTGRES_USER=invoice_user
POSTGRES_PASSWORD=invoice_pass
POSTGRES_PORT=5432

RUST_LOG=info

PSP_BIND_ADDR=0.0.0.0:8081
PSP_PORT=8081

API_BIND_ADDR=0.0.0.0:8080
API_PORT=8080

# Internal service-to-service URLs inside docker network
PSP_BASE_URL=http://localhost:8081
DATABASE_URL=postgres://invoice_user:invoice_pass@localhost:55432/invoice_db

WORKER_POLL_INTERVAL_MS=2000

# Optional pepper used in API key hashing. Keep this stable per environment.
API_KEY_PEPPER=local-dev-pepper-2026
BASE_URL=http://localhost:8080